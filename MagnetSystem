while true do
	task.wait(0.05)

	for _, player in pairs(game.Players:GetPlayers()) do
		local char = player.Character
		if not char then continue end

		local root = char:FindFirstChild("HumanoidRootPart")
		local magnet = player:FindFirstChild("Magnet")

		if not root or not magnet then continue end

		for _, obj in pairs(workspace:GetChildren()) do
			if obj:IsA("Part") and obj.Name == "Sugar" then

				local dist = (obj.Position - root.Position).Magnitude

				-- RANGE scales
				if dist < magnet.Value then

					-- SPEED scales 🔥
					local strength = math.clamp(magnet.Value / 50, 0.2, 1)

					obj.Position = obj.Position:Lerp(root.Position, strength)
				end
			end
		end
	end
end
