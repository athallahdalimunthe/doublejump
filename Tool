local tool = script.Parent
local sound = tool:FindFirstChild("Sound")
local particles = tool.Handle:FindFirstChildOfClass("ParticleEmitter")

local boost = 30
local active = false

tool.Equipped:Connect(function()
	local player = game.Players:GetPlayerFromCharacter(tool.Parent)
	if not player then return end

	local magnet = player:FindFirstChild("Magnet")
	if magnet then
		magnet.Value += boost
	end

	active = true

	-- play sound
	if sound then
		sound:Play()
	end

	-- particles ON
	if particles then
		particles.Enabled = true
	end
end)

tool.Unequipped:Connect(function()
	local player = game.Players:GetPlayerFromCharacter(tool.Parent)
	if not player then return end

	local magnet = player:FindFirstChild("Magnet")
	if magnet then
		magnet.Value -= boost
	end

	active = false

	-- stop effects
	if sound then
		sound:Stop()
	end

	if particles then
		particles.Enabled = false
	end
end)
