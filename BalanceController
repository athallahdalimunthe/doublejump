local character = script.Parent
local humanoid = character:WaitForChild("Humanoid")
local root = character:WaitForChild("HumanoidRootPart")

local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")

-- SETTINGS
local maxJumps = 8
local jumpPower = 87
local rechargeRate = 1 -- seconds per jump

local jumpCount = 0
local canJump = true

-- UI VALUE
local jumpsLeftValue = Instance.new("IntValue")
jumpsLeftValue.Name = "JumpsLeft"
jumpsLeftValue.Value = maxJumps
jumpsLeftValue.Parent = character

-- 🔊 JUMP SOUND
local jumpSound = Instance.new("Sound")
jumpSound.SoundId = "rbxassetid://12222225" -- you can change this
jumpSound.Volume = 1
jumpSound.Parent = root

-- Reset when touching ground
humanoid.StateChanged:Connect(function(old, new)
	if new == Enum.HumanoidStateType.Landed then
		canJump = true
	end
end)

-- JUMP SYSTEM (works PC + mobile)
UserInputService.JumpRequest:Connect(function()
	if jumpCount < maxJumps and canJump then
		jumpCount += 1

		-- apply jump
		root.Velocity = Vector3.new(
			root.Velocity.X,
			jumpPower,
			root.Velocity.Z
		)

		-- 🔊 PLAY SOUND (safe replay)
		jumpSound.PlaybackSpeed = math.random(90,110) / 100
		jumpSound:Stop()
		jumpSound:Play()

		-- update UI
		jumpsLeftValue.Value = maxJumps - jumpCount

		canJump = false

		task.delay(0.1, function()
			canJump = true
		end)
	end
end)

-- AIR CONTROL
RunService.RenderStepped:Connect(function()
	if humanoid:GetState() == Enum.HumanoidStateType.Freefall then
		local moveDir = humanoid.MoveDirection

		root.Velocity += Vector3.new(
			moveDir.X * 2,
			0,
			moveDir.Z * 2
		)
	end
end)

-- RECHARGE SYSTEM
task.spawn(function()
	while true do
		task.wait(rechargeRate)

		if jumpsLeftValue.Value < maxJumps then
			if humanoid:GetState() ~= Enum.HumanoidStateType.Freefall then

				jumpsLeftValue.Value += 1

				-- sync jumpCount with UI
				jumpCount = maxJumps - jumpsLeftValue.Value
			end
		end
	end
end)
